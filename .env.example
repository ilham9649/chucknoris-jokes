# AWS Configuration
AWS_REGION=ap-southeast-3
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# SSH Key Configuration
SSH_KEY_NAME=your-existing-key-pair-name
SSH_PRIVATE_KEY_PATH=/path/to/your/private-key.pem

# Application
APP_NAME=chucknoris-jokes
APP_PORT=80

# Terraform Variables (used as TF_VAR_* environment variables)
TF_VAR_region=ap-southeast-3
TF_VAR_instance_type=t2.micro
TF_VAR_key_name=your-existing-key-pair-name
TF_VAR_environment=dev
