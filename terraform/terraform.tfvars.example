# Copy this file to terraform.tfvars and update the values
# IMPORTANT: Never commit terraform.tfvars to version control

region            = "ap-southeast-3"
instance_type     = "t3.nano"
key_name          = "your-existing-key-pair-name"  # Replace with your AWS key pair name
environment       = "dev"
project_name      = "chucknoris-jokes"

# VPC Configuration
# Leave null to use default VPC
# Or specify custom VPC ID: vpc_id = "vpc-0123456789abcdef0"
vpc_id            = null

# Subnet Configuration
# Leave null to auto-select public subnet with Internet Gateway route
# Or specify custom subnet ID: subnet_id = "subnet-0123456789abcdef0"
# IMPORTANT: Custom subnet must have public IP assignment enabled and route to IGW
subnet_id         = null

# Security: Leave null to auto-detect your current public IP
# Or specify specific IPs: allowed_ssh_cidr = ["203.0.113.0/24"]
# Note: SSH is optional when using AWS SSM for instance access
allowed_ssh_cidr  = null
